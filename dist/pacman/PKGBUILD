# Maintainer: Lukas Wölfer <lukas.woelfer@rwth-aachen.de>
# VCS package — builds diaria from the latest main of corrodedHash/diaria-rs.
# The committed pkgver is a placeholder; pkgver() recomputes it at build time.

pkgname=diaria
pkgver=0.2.0.r3.g85e0014
pkgrel=1
pkgdesc="Encrypted, plain-text command-line diary"
arch=('x86_64' 'aarch64')
url="https://github.com/corrodedHash/diaria-rs"
license=('MIT')
makedepends=('cargo' 'git')
provides=('diaria')
conflicts=('diaria' 'diaria-git')
source=("$pkgname::git+https://github.com/corrodedHash/diaria-rs.git")
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/$pkgname"
    git describe --tags --long --match 'v*' | sed 's/^v//; s/-/.r/; s/-/./g'
}

prepare() {
    cd "$srcdir/$pkgname"
    cargo fetch --locked
}

build() {
    cd "$srcdir/$pkgname"
    cargo build --release --frozen --locked
}

check() {
    cd "$srcdir/$pkgname"
    cargo test --frozen --locked
}

package() {
    cd "$srcdir/$pkgname"
    install -Dm755 target/release/diaria "$pkgdir/usr/bin/diaria"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
